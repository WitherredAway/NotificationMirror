<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Send as:"
        android:textSize="13sp"
        android:textColor="?colorOnSurfaceVariant" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/testAppIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/testAppName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="16sp"
            android:textColor="?colorOnSurface"
            android:text="Notification Mirror" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/selectAppButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Change"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>

    <!-- Notification type selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Notification type:"
        android:textSize="13sp"
        android:textColor="?colorOnSurfaceVariant" />

    <Spinner
        android:id="@+id/testTypeSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@android:drawable/btn_dropdown"
        android:padding="8dp" />

    <!-- Type description -->
    <TextView
        android:id="@+id/testTypeDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="11sp"
        android:textColor="?colorOnSurfaceVariant"
        android:text="Basic notification with title and message" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Title"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/testTitleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Notification"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Message"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/testTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is a test notification from Notification Mirror"
            android:textSize="14sp"
            android:minLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Count (for burst/conversation types) -->
    <LinearLayout
        android:id="@+id/testCountRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/testCountLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Count:"
            android:textSize="13sp"
            android:textColor="?colorOnSurface" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/testCountInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="14sp"
                android:inputType="number"
                android:gravity="center" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Delay between burst notifications -->
    <LinearLayout
        android:id="@+id/testDelayRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delay (ms):"
            android:textSize="13sp"
            android:textColor="?colorOnSurface" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/testDelayInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="500"
                android:textSize="14sp"
                android:inputType="number"
                android:gravity="center" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

</LinearLayout>
</ScrollView>
