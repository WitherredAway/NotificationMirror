<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="?android:colorBackground">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textSize="22sp" android:textStyle="bold" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="BEHAVIOR" android:textSize="12sp" android:textStyle="bold" android:textColor="?colorPrimary" android:letterSpacing="0.1" />
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DND Sync" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Skip mirroring when phone is in Do Not Disturb mode" android:textSize="12sp" android:textColor="?colorOutline" />
</LinearLayout>
<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/dndSyncSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mirror Ongoing Notifications" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Include persistent/ongoing notifications (music, timers, etc.)" android:textSize="12sp" android:textColor="?colorOutline" />
</LinearLayout>
<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/mirrorOngoingSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Auto-Dismiss Sync" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Dismiss watch notification when dismissed on phone" android:textSize="12sp" android:textColor="?colorOutline" />
</LinearLayout>
<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/autoDismissSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Screen-Off Mirroring" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Control mirroring behavior based on phone screen state" android:textSize="12sp" android:textColor="?colorOutline" />
<RadioGroup android:id="@+id/screenModeGroup" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical">
<RadioButton android:id="@+id/radioAlways" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Always mirror" android:textSize="14sp" android:textColor="?colorOnSurface" android:paddingStart="8dp" />
<RadioButton android:id="@+id/radioScreenOff" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Only mirror when screen is off" android:textSize="14sp" android:textColor="?colorOnSurface" android:paddingStart="8dp" />
<RadioButton android:id="@+id/radioSilent" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mirror always, but silent when screen is on" android:textSize="14sp" android:textColor="?colorOnSurface" android:paddingStart="8dp" />
</RadioGroup>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="WATCH NOTIFICATIONS" android:textSize="12sp" android:textStyle="bold" android:textColor="?colorPrimary" android:letterSpacing="0.1" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Notification Priority" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Controls how prominently notifications appear on watch" android:textSize="12sp" android:textColor="?colorOutline" />
<RadioGroup android:id="@+id/priorityGroup" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical">
<RadioButton android:id="@+id/radioPriorityHigh" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="High (heads-up, sound, vibration)" android:textSize="14sp" android:textColor="?colorOnSurface" android:paddingStart="8dp" />
<RadioButton android:id="@+id/radioPriorityDefault" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Default (no heads-up, sound + vibration)" android:textSize="14sp" android:textColor="?colorOnSurface" android:paddingStart="8dp" />
<RadioButton android:id="@+id/radioPriorityLow" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Low (silent, no vibration)" android:textSize="14sp" android:textColor="?colorOnSurface" android:paddingStart="8dp" />
</RadioGroup>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Auto-Cancel on Tap" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Dismiss notification when tapped on watch" android:textSize="12sp" android:textColor="?colorOutline" />
</LinearLayout>
<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/autoCancelSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Show Open on Watch Button" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Add button to open companion app when available" android:textSize="12sp" android:textColor="?colorOutline" />
</LinearLayout>
<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/showOpenButtonSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Show Mute Button" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Add quick-mute button on watch notifications" android:textSize="12sp" android:textColor="?colorOutline" />
</LinearLayout>
<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/showMuteButtonSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Expanded Text Threshold" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Text longer than this will show in expanded view on watch" android:textSize="12sp" android:textColor="?colorOutline" />
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal" android:gravity="center_vertical">
<EditText android:id="@+id/bigTextThresholdInput" android:layout_width="80dp" android:layout_height="wrap_content" android:inputType="number" android:textSize="16sp" android:textColor="?colorOnSurface" android:gravity="center" android:padding="10dp" android:background="@drawable/edit_text_bg" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="characters" android:textSize="14sp" android:textColor="?colorOnSurfaceVariant" />
</LinearLayout>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="QUICK MUTE" android:textSize="12sp" android:textStyle="bold" android:textColor="?colorPrimary" android:letterSpacing="0.1" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Mute Duration" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Duration for the Mute button on watch notifications" android:textSize="12sp" android:textColor="?colorOutline" />
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal" android:gravity="center_vertical">
<EditText android:id="@+id/muteDurationInput" android:layout_width="80dp" android:layout_height="wrap_content" android:inputType="number" android:textSize="16sp" android:textColor="?colorOnSurface" android:gravity="center" android:padding="10dp" android:background="@drawable/edit_text_bg" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="minutes" android:textSize="14sp" android:textColor="?colorOnSurfaceVariant" />
</LinearLayout>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="VIBRATION" android:textSize="12sp" android:textStyle="bold" android:textColor="?colorPrimary" android:letterSpacing="0.1" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Default Vibration Pattern" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Used for apps without a custom pattern. Comma-separated ms." android:textSize="12sp" android:textColor="?colorOutline" />
<EditText android:id="@+id/defaultVibrationInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:inputType="text" android:textSize="14sp" android:textColor="?colorOnSurface" android:padding="10dp" android:background="@drawable/edit_text_bg" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Per-App Vibration Patterns" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Override vibration for specific apps." android:textSize="12sp" android:textColor="?colorOutline" />
<com.google.android.material.button.MaterialButton android:id="@+id/selectVibAppButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="12dp" android:text="Select App" android:textAllCaps="false" android:textSize="14sp" style="@style/Widget.Material3.Button.TonalButton" />
<TextView android:id="@+id/vibAppDisplay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textSize="14sp" android:textColor="?colorPrimary" android:visibility="gone" />
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal" android:gravity="center_vertical">
<EditText android:id="@+id/vibPatternInput" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="0,200,100,200" android:inputType="text" android:textSize="13sp" android:textColor="?colorOnSurface" android:textColorHint="?colorOutline" android:padding="10dp" android:background="@drawable/edit_text_bg" />
<com.google.android.material.button.MaterialButton android:id="@+id/addVibButton" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="Set" android:textAllCaps="false" android:textSize="13sp" android:minWidth="0dp" android:paddingStart="16dp" android:paddingEnd="16dp" />
</LinearLayout>
<TextView android:id="@+id/customVibrationsText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="12dp" android:textSize="12sp" android:textColor="?colorOnSurfaceVariant" android:lineSpacingExtra="2dp" android:background="@drawable/edit_text_bg" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="NOTIFICATION SOUND" android:textSize="12sp" android:textStyle="bold" android:textColor="?colorPrimary" android:letterSpacing="0.1" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Per-App Notification Sound" android:textSize="16sp" android:textColor="?colorOnSurface" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Set a custom notification sound for specific apps on the watch." android:textSize="12sp" android:textColor="?colorOutline" />
<com.google.android.material.button.MaterialButton android:id="@+id/selectSoundAppButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="12dp" android:text="Select App" android:textAllCaps="false" android:textSize="14sp" style="@style/Widget.Material3.Button.TonalButton" />
<TextView android:id="@+id/soundAppDisplay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textSize="14sp" android:textColor="?colorPrimary" android:visibility="gone" />
<com.google.android.material.button.MaterialButton android:id="@+id/pickSoundButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:text="Pick Sound" android:textAllCaps="false" android:textSize="14sp" style="@style/Widget.Material3.Button.TonalButton" />
<TextView android:id="@+id/soundNameDisplay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textSize="13sp" android:textColor="?colorOnSurfaceVariant" android:visibility="gone" />
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal" android:gravity="center_vertical">
<com.google.android.material.button.MaterialButton android:id="@+id/setSoundButton" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Set Sound" android:textAllCaps="false" android:textSize="13sp" />
<com.google.android.material.button.MaterialButton android:id="@+id/clearSoundButton" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="Clear" android:textAllCaps="false" android:textSize="13sp" style="@style/Widget.Material3.Button.TonalButton" />
</LinearLayout>
<TextView android:id="@+id/customSoundsText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="12dp" android:textSize="12sp" android:textColor="?colorOnSurfaceVariant" android:lineSpacingExtra="2dp" android:background="@drawable/edit_text_bg" />
<com.google.android.material.button.MaterialButton android:id="@+id/saveSettingsButton" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="24dp" android:layout_marginBottom="24dp" android:text="Save Settings" android:textAllCaps="false" android:textSize="16sp" />
</LinearLayout>
</ScrollView>
